# =============================================================================
# Portfolio Performance API — Git ignore rules
# =============================================================================

# -----------------------------------------------------------------------------
# Maven / Java build output
# -----------------------------------------------------------------------------
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Compiled class files
*.class

# Package files
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# JVM crash logs
hs_err_pid*
replay_pid*

# -----------------------------------------------------------------------------
# Spring Boot
# -----------------------------------------------------------------------------
.springBeans

# -----------------------------------------------------------------------------
# Logs and runtime files
# -----------------------------------------------------------------------------
*.log
logs/
spring.log

# -----------------------------------------------------------------------------
# Environment, secrets, and local config (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env.local
*.env.*.local
secrets/
credentials/
*.pem
*.key
*.p12
*.jks
*.keystore
application-local.yml
application-local.properties
application-*.local.yml
application-*.local.properties

# -----------------------------------------------------------------------------
# IDE — IntelliJ IDEA
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
out/

# -----------------------------------------------------------------------------
# IDE — Eclipse / STS
# -----------------------------------------------------------------------------
.apt_generated/
.classpath
.factorypath
.project
.settings/
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
.sts4-cache/

# -----------------------------------------------------------------------------
# IDE — VS Code / Cursor (local editor state only)
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.code-workspace

# Cursor local/cache (keep .cursor/skills/ — project deliverables)
.cursor/chat/
.cursor/cache/
.cursor/plans/
.cursor/**/*.log

# -----------------------------------------------------------------------------
# IDE — NetBeans
# -----------------------------------------------------------------------------
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Test / coverage reports (generated locally)
# -----------------------------------------------------------------------------
/test-output/
/coverage/
*.exec
.jacoco/
jacoco.exec
surefire-reports/
failsafe-reports/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.orig
*.rej
.attach_pid*
.factorypath

.cursor/skills/calculation-reviewer/SKILL.md
